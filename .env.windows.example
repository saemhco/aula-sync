# Windows Server — solo API Aula Sync (sin contenedor SQL)
# Moodle corre en otro despliegue; instalar alli el plugin local_aulasync.

# SQL Server — completar en .env (no commitear credenciales)
DB_HOST=
DB_PORT=11433
DB_DATABASE=DB_UNHEVAL
DB_USERNAME=
DB_PASSWORD=

# Moodle: URL que usa la API para llamar al plugin / integracion
MOODLE_URL=
MOODLE_PUBLIC_URL=

# SQLite — rutas Windows con barras normales
SETTINGS_DB_PATH=C:/apps/aula-sync/data/settings.db

# Usuario del panel (se crea en el primer arranque si no existe)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=

# Cifrar token de integracion Moodle en SQLite
INTEGRATION_TOKEN_KEY=

# URL publica de este servidor API (Moodle la vincula al token del plugin)
AULA_SYNC_PUBLIC_URL=http://servidor:8092
