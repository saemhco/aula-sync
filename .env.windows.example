# Windows Server — solo API Aula Sync (sin contenedor SQL)
# Moodle corre en otro despliegue; instalar allí el plugin local_aulasync.

# SQL Server en red local / intranet UNHEVAL
DB_HOST=10.19.14.72
DB_PORT=1433
DB_DATABASE=DB_UNHEVAL
DB_USERNAME=aulavirtualunh
DB_PASSWORD=change-me

# Moodle: URL que usa la API para llamar al plugin / integracion
MOODLE_URL=https://aulasvirtuales.unheval.edu.pe
# URL pública de Moodle (Host header hacia integracion / plugin)
MOODLE_PUBLIC_URL=https://aulasvirtuales.unheval.edu.pe

# SQLite — rutas Windows con barras normales
SETTINGS_DB_PATH=C:/apps/aula-sync/data/settings.db

# Usuario del panel (se crea en el primer arranque si no existe)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-on-first-deploy

# Cifrar token de integración Moodle en SQLite
INTEGRATION_TOKEN_KEY=change-me-use-openssl-rand-base64-32

# URL pública de este servidor API (Moodle la vincula al token del plugin)
AULA_SYNC_PUBLIC_URL=http://servidor:8092
