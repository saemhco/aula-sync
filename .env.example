# =============================================================================
# Conexion SQL Server (API) — dev y produccion
# Windows Server: solo DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD
# =============================================================================
DB_HOST=sqlserver
DB_PORT=1433
DB_DATABASE=DB_UNHEVAL
DB_USERNAME=
DB_PASSWORD=

# =============================================================================
# Solo Docker local (COMPOSE_PROFILES=local-db) — NO usar en Windows Server
# MSSQL_SA_PASSWORD = password del usuario SA del contenedor SQL Server
# MSSQL_HOST_PORT = puerto expuesto en el host (SSMS: localhost,11433)
# =============================================================================
COMPOSE_PROFILES=local-db
MSSQL_SA_PASSWORD=
MSSQL_HOST_PORT=11433

# Puertos no estandar
API_PORT=8092

# Moodle: host.docker.internal = contenedor -> host; localhost = URL visible en el panel
MOODLE_URL=http://host.docker.internal:8046
MOODLE_PUBLIC_URL=http://localhost:8046

# SQLite local para origen/destino activos
# Linux/Docker: /app/data/settings.db  |  Windows: C:/apps/aula-sync/data/settings.db
SETTINGS_DB_PATH=/app/data/settings.db

# Usuario local del panel (SQLite). Se crea solo si no hay usuarios.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=

# Clave para cifrar tokens de integracion en SQLite
INTEGRATION_TOKEN_KEY=

# URL publica de Aula Sync; Moodle la vincula al token en la primera peticion
AULA_SYNC_PUBLIC_URL=http://localhost:8092
