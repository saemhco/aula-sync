# SQL Server
MSSQL_SA_PASSWORD=AulaSync2024!Strong
DB_HOST=sqlserver
# Red interna Docker → sqlserver escucha en 1433. Desde el host (SSMS, etc.) usa MSSQL_HOST_PORT.
DB_PORT=1433
MSSQL_HOST_PORT=11433
DB_DATABASE=DB_YOUR_DATABASE
DB_USERNAME=username
DB_PASSWORD=change-me

# Puertos no estándar (evitar 80, 443, 8000, 1433 expuestos en el host)
API_PORT=8092

# Docker Compose: perfil "local-db" levanta SQL Server en contenedor.
# Desarrollo local: COMPOSE_PROFILES=local-db  y  DB_HOST=sqlserver
# Windows Server / BD externa: dejar vacío y DB_HOST=host.docker.internal (o IP del servidor)
COMPOSE_PROFILES=local-db

# Moodle: host.docker.internal = contenedor → host; localhost = URL visible en el panel
MOODLE_URL=http://host.docker.internal:8046
MOODLE_PUBLIC_URL=http://localhost:8046

# SQLite local para origen/destino activos
# Linux/Docker: /app/data/settings.db  |  Windows: C:/apps/aula-sync/data/settings.db
SETTINGS_DB_PATH=/app/data/settings.db

# Usuario local del panel (SQLite). Se crea solo si no hay usuarios.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-on-first-deploy

# Clave para cifrar tokens de integración en SQLite (no guardar el token en texto plano)
INTEGRATION_TOKEN_KEY=change-me-in-production-use-openssl-rand-base64-32

# URL pública de Aula Sync; Moodle la vincula al token en la primera petición
AULA_SYNC_PUBLIC_URL=http://localhost:8092
